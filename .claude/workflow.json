{
  "commands": {
    "test": "npx vitest run --reporter=verbose && cd server && npx vitest run --reporter=verbose --exclude=\"__tests__/integration/real-auth-flow.test.ts\"",
    "test_frontend": "npx vitest run --reporter=verbose",
    "test_server": "cd server && npx vitest run --reporter=verbose",
    "test_hooks": "python -m pytest .claude/hooks/tests/ -v",
    "lint": "ruff check .",
    "format": "ruff format .",
    "regression": "npx vitest run --reporter=verbose && cd server && npx vitest run --reporter=verbose --exclude=\"__tests__/routes/messages.test.ts\" --exclude=\"__tests__/routes/dispatch-flow.test.ts\" --exclude=\"__tests__/routes/load-crud.test.ts\" --exclude=\"__tests__/routes/incidents-crud.test.ts\" --exclude=\"__tests__/routes/ai.test.ts\" --exclude=\"__tests__/routes/call-sessions.test.ts\"",
    "regression_default_tier": "unit",
    "regression_tiers": {
      "smoke": {
        "cmd": "python -m pytest .claude/hooks/tests/ -v --tb=short --ignore=.claude/hooks/tests/test_qa_runner.py --ignore=.claude/hooks/tests/test_story007_hardening.py -q -x",
        "max_duration_s": 120
      },
      "unit": {
        "cmd": "python -m pytest .claude/hooks/tests/ -v --tb=short --ignore=.claude/hooks/tests/test_qa_runner.py --ignore=.claude/hooks/tests/test_story007_hardening.py --ignore=.claude/hooks/tests/test_r_p2_story002.py -q --ignore=.claude/hooks/tests/test_r_p3_deploy_staging_scripts.py",
        "max_duration_s": 600
      },
      "full": {
        "cmd": "python -m pytest .claude/hooks/tests/ -v --tb=long",
        "max_duration_s": 600
      },
      "story005_docs": {
        "cmd": "python -m pytest .claude/hooks/tests/test_r_p4_golive_story005.py -v --tb=short -q",
        "max_duration_s": 60
      },
      "story001_cloud_sql": {
        "cmd": "cd server && npx vitest run __tests__/unit/db-connection.test.ts --reporter=verbose",
        "max_duration_s": 60
      },
      "story003_deploy_scripts": {
        "cmd": "python -m pytest .claude/hooks/tests/test_r_p3_deploy_staging_scripts.py -v --tb=short -q",
        "max_duration_s": 120
      },
      "story004_rollback_monitoring": {
        "cmd": "python -m pytest .claude/hooks/tests/test_r_p4_rollback_monitoring.py -v --tb=short -q",
        "max_duration_s": 90
      },
      "story005_deploy_prep": {
        "cmd": "python -m pytest .claude/hooks/tests/test_r_p5_deployment.py .claude/hooks/tests/test_r_p5_story005.py .claude/hooks/tests/test_r_p5_deploy_prep_story005.py -v --tb=short -q",
        "max_duration_s": 120
      }
    },
    "coverage": ""
  },
  "test_patterns": [
    "vitest",
    "npx vitest"
  ],
  "format_timeout_seconds": 30,
  "qa_runner": {
    "production_scan": {
      "enabled": true,
      "fail_on_violation": true,
      "exclude_patterns": [
        "test_*",
        "*_test.*"
      ]
    },
    "custom_steps": []
  },
  "test_quality": {
    "min_assertions_per_test": 1,
    "detect_self_mocks": true,
    "detect_mock_only": true
  },
  "verification_log": {
    "format": "jsonl",
    "max_entries": 1000,
    "path": ".claude/docs/verification-log.jsonl"
  },
  "plan_sync": {
    "mode": "check",
    "action": "warn"
  },
  "external_scanners": {
    "bandit": {
      "cmd": "bandit -r {changed_dir} -f json -q",
      "enabled": false,
      "strict_mode": false
    },
    "semgrep": {
      "cmd": "semgrep --config=auto {changed_dir} --json -q",
      "enabled": false
    },
    "pip-audit": {
      "cmd": "pip-audit --format=json",
      "enabled": true,
      "strict_mode": false
    }
  },
  "agent_config": {
    "ralph_worker": {
      "maxTurns": 150
    },
    "complexity_thresholds": {
      "simple": {
        "max_score": 6,
        "maxTurns": 100
      },
      "medium": {
        "max_score": 12,
        "maxTurns": 150
      },
      "complex": {
        "maxTurns": 200
      }
    }
  },
  "audit_modes": {
    "quick": {
      "sections": [
        1,
        2,
        6
      ],
      "description": "Fast structural check \u00e2\u20ac\u201d PLAN.md completeness (1), prd.json alignment (2), hook chain health (6). No file scanning, no test tracing."
    },
    "delivery": {
      "sections": [
        1,
        2,
        3,
        4
      ],
      "description": "Production-relevant surfaces for release gating \u00e2\u20ac\u201d plan (1), PRD (2), test coverage traceability (3), verification log integrity (4)."
    },
    "full": {
      "sections": [
        1,
        2,
        3,
        4,
        5,
        6,
        7,
        8,
        9
      ],
      "description": "Exhaustive audit \u00e2\u20ac\u201d all 9 sections. Current default behavior, unchanged."
    }
  },
  "languages": {
    "python": {
      "extensions": [
        ".py"
      ],
      "test_patterns": [
        "test_*.py",
        "*_test.py"
      ],
      "commands": {
        "lint": "ruff check .",
        "type_check": "mypy .claude/hooks/ --exclude .claude/hooks/tests --ignore-missing-imports --no-error-summary",
        "test": "python -m pytest .claude/hooks/tests/ -v"
      }
    },
    "typescript": {
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "test_patterns": [
        "*.test.ts",
        "*.test.tsx"
      ],
      "commands": {
        "lint": "npx tsc --noEmit",
        "type_check": "npx tsc --noEmit",
        "test": "npx vitest run --reporter=verbose",
        "test_server": "cd server && npx vitest run --reporter=verbose"
      }
    }
  }
}
