{
  "commands": {
    "test": "npx vitest run --reporter=verbose && cd server && npx vitest run --reporter=verbose --exclude=\"__tests__/integration/real-auth-flow.test.ts\"",
    "test_frontend": "npx vitest run --reporter=verbose",
    "test_server": "cd server && npx vitest run --reporter=verbose",
    "test_hooks": "python -m pytest .claude/hooks/tests/ -v",
    "lint": "ruff check .",
    "format": "ruff format .",
    "regression": "python -m pytest .claude/hooks/tests/ -v --tb=short",
    "regression_default_tier": "unit",
    "regression_tiers": {
      "smoke": {
        "cmd": "python -m pytest .claude/hooks/tests/ -v --tb=short -x -q",
        "max_duration_s": 60
      },
      "unit": {
        "cmd": "python -m pytest .claude/hooks/tests/ -v --tb=short",
        "max_duration_s": 1800
      },
      "full": {
        "cmd": "python -m pytest .claude/hooks/tests/ -v --tb=long",
        "max_duration_s": 600
      },
      "docs": {
        "cmd": "python -m pytest .claude/hooks/tests/test_r_p4_01.py -v --tb=short",
        "max_duration_s": 120
      }
    },
    "coverage": "",
    "coverage_timeout_s": 1200,
    "type_check": "mypy .claude/hooks/ --ignore-missing-imports --no-error-summary",
    "unit_timeout_s": 600
  },
  "test_patterns": [
    "vitest",
    "npx vitest"
  ],
  "format_timeout_seconds": 30,
  "qa_runner": {
    "production_scan": {
      "enabled": true,
      "fail_on_violation": true,
      "exclude_patterns": [
        "test_*",
        "*_test.*"
      ]
    },
    "custom_steps": [],
    "evidence_max_chars": 500
  },
  "test_quality": {
    "min_assertions_per_test": 1,
    "detect_self_mocks": true,
    "detect_mock_only": true
  },
  "verification_log": {
    "format": "jsonl",
    "max_entries": 1000,
    "path": ".claude/docs/verification-log.jsonl"
  },
  "plan_sync": {
    "mode": "check",
    "action": "warn"
  },
  "external_scanners": {
    "bandit": {
      "cmd": "bandit -r {changed_dir} -f json -q",
      "enabled": true,
      "strict_mode": false
    },
    "semgrep": {
      "cmd": "semgrep --config=auto {changed_dir} --json -q",
      "enabled": false
    },
    "pip-audit": {
      "cmd": "pip-audit --format=json",
      "enabled": true,
      "strict_mode": false
    }
  },
  "agent_config": {
    "ralph_worker": {
      "maxTurns": 250
    },
    "complexity_thresholds": {
      "simple": {
        "max_score": 6,
        "maxTurns": 100
      },
      "medium": {
        "max_score": 12,
        "maxTurns": 150
      },
      "complex": {
        "maxTurns": 250
      }
    }
  },
  "audit_modes": {
    "quick": {
      "sections": [
        1,
        2,
        6
      ],
      "description": "Fast structural check — PLAN.md completeness (1), prd.json alignment (2), hook chain health (6). No file scanning, no test tracing."
    },
    "delivery": {
      "sections": [
        1,
        2,
        3,
        4
      ],
      "description": "Production-relevant surfaces for release gating — plan (1), PRD (2), test coverage traceability (3), verification log integrity (4)."
    },
    "full": {
      "sections": [
        1,
        2,
        3,
        4,
        5,
        6,
        7,
        8,
        9
      ],
      "description": "Exhaustive audit — all 9 sections. Current default behavior, unchanged."
    }
  },
  "languages": {
    "python": {
      "extensions": [
        ".py"
      ],
      "test_patterns": [
        "test_*.py",
        "*_test.py"
      ],
      "commands": {
        "lint": "ruff check .",
        "type_check": "mypy .claude/hooks/ --exclude .claude/hooks/tests --ignore-missing-imports --no-error-summary",
        "test": "python -m pytest .claude/hooks/tests/ -v"
      }
    },
    "typescript": {
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "test_patterns": [
        "*.test.ts",
        "*.test.tsx"
      ],
      "commands": {
        "lint": "npx tsc --noEmit",
        "type_check": "npx tsc --noEmit",
        "test": "npx vitest run --reporter=verbose",
        "test_server": "cd server && npx vitest run --reporter=verbose"
      }
    }
  },
  "ralph": {
    "circuit_breaker_threshold": 3,
    "drift_threshold": 3
  },
  "_timeout_notes": "Per-step timeouts (unit_timeout_s, coverage_timeout_s) apply to individual test commands in qa_runner steps. Regression tier max_duration_s applies to full regression runs in STEP 2/6. Tier timeouts take precedence when running regression commands."
}
