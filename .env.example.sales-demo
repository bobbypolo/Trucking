# Sales Demo env contract — single source of truth for seed, reset, certify
#
# Copy this file to .env.local at the repo root and fill in real values.
# Seed, reset, and certify scripts ALL load from .env.local (never .env).
# See docs/sales-demo-seed-contract.md for provisioning instructions.

# --- Database credentials ------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=<fill-in>
DB_PASSWORD=<fill-in>
DB_NAME=<fill-in-but-never-production>

# --- Firebase Auth UIDs (provisioned manually via Firebase Console) ------------
# Create two Firebase Auth users (admin + driver) before running the seed, then
# paste their UIDs here. The seed script FAILS FAST if either value is missing.
# See docs/sales-demo-seed-contract.md "Firebase UID env contract" section.
SALES_DEMO_ADMIN_FIREBASE_UID=<fill-in>
SALES_DEMO_DRIVER_FIREBASE_UID=<fill-in>

# --- Demo runtime flags (required by runbook) ----------------------------------
# VITE_DEMO_NAV_MODE=sales collapses the sidebar to the 6 certified demo routes.
# ALLOW_DEMO_RESET=1 enables the POST /api/demo/reset endpoint + Reset button.
# See docs/sales-demo-runbook.md for full details.
VITE_DEMO_NAV_MODE=sales
ALLOW_DEMO_RESET=1

# --- Firebase client config ----------------------------------------------------
# These values are required for the sales demo host and for the certified
# Playwright flow. GitHub Actions injects them into CI; the local demo host reads
# the same keys from .env.local.
FIREBASE_WEB_API_KEY=<fill-in>
VITE_FIREBASE_API_KEY=<fill-in>
VITE_FIREBASE_AUTH_DOMAIN=<fill-in>
VITE_FIREBASE_PROJECT_ID=<fill-in>
VITE_FIREBASE_STORAGE_BUCKET=<fill-in>
VITE_FIREBASE_MESSAGING_SENDER_ID=<fill-in>
VITE_FIREBASE_APP_ID=<fill-in>

# --- Gemini (server-side AI) ---------------------------------------------------
# Required on the actual demo host if you want the live driver intake / wow path.
GEMINI_API_KEY=<fill-in>

# --- Firebase Auth credentials (for browser-based certification) ----------------
# The certification suite logs in through the real browser UI as both the admin
# and driver demo users. Use the same accounts whose UIDs appear above.
SALES_DEMO_ADMIN_EMAIL=<fill-in>
SALES_DEMO_ADMIN_PASSWORD=<fill-in>
SALES_DEMO_DRIVER_EMAIL=<fill-in>
SALES_DEMO_DRIVER_PASSWORD=<fill-in>
