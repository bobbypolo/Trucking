# Firebase Frontend Configuration (Vite)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# API URL — set to your production backend URL (required for production builds)
# Defaults to http://localhost:5000/api in development if not set
VITE_API_URL=https://api.yourdomain.com/api

# Google Gemini AI API Key (must be VITE-prefixed to be included in browser bundle)
# Get your key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Microsoft Weather API (Azure Maps)
# Get your key from: https://azure.microsoft.com/en-us/products/azure-maps
VITE_WEATHER_API_KEY=your_azure_maps_subscription_key_here

# Backend Configuration
# The server looks for server/serviceAccount.json by default.
# JWT_SECRET=your_jwt_secret_here (Optional if using Firebase only)

# CORS — set to your frontend domain in production (comma-separated for multiple origins)
# Defaults to * (all origins) if not set — configure before production deployment
CORS_ORIGIN=https://yourdomain.com

# Rate Limiting — maximum requests per IP per 15 minutes on /api routes
# Defaults to 100 if not set
RATE_LIMIT_MAX=100

# Node environment (development|production|test)
NODE_ENV=development
