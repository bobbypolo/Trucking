# ============================================================================
# LoadPilot Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
#
# Variables are grouped by feature. Required vars are marked [REQUIRED];
# optional vars show their default value after the equals sign.
# ============================================================================

# --- Firebase Frontend Configuration (Vite) ----------------------------------
# These VITE_FIREBASE_* vars configure the Firebase JS SDK in the browser.
# Get them from: Firebase Console > Project Settings > General > Your apps
# [REQUIRED] All six are needed for authentication and Firestore to work.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# [OPTIONAL] Firebase Analytics measurement ID. Omit to disable analytics.
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Frontend API URL --------------------------------------------------------
# [OPTIONAL] Base URL for the Express API backend.
# Defaults to /api (proxied via Vite in development).
# Set to /api or https://api.yourdomain.com/api for production builds.
# VITE_API_URL=/api

# --- Dev Server Ports --------------------------------------------------------
# [OPTIONAL] Frontend Vite dev server port. Defaults to 3101.
# VITE_PORT=3101

# [OPTIONAL] Backend port that Vite proxies /api to in development. Defaults to 5000.
# VITE_BACKEND_PORT=5000

# --- Google Maps (Frontend) --------------------------------------------------
# [REQUIRED for fleet map] Powers GlobalMapView, geocoding, directions, and
# distance matrix in the browser. Without this key, map pages show a
# configuration prompt instead of rendering.
# Get your key from: https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API, Geocoding API, Directions API, Distance Matrix API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- Weather (Frontend) ------------------------------------------------------
# [OPTIONAL] Azure Maps subscription key for route weather overlays.
# Get your key from: https://azure.microsoft.com/en-us/products/azure-maps
# VITE_WEATHER_API_KEY=your_azure_maps_subscription_key_here

# [OPTIONAL] OpenWeatherMap fallback -- used when VITE_WEATHER_API_KEY is empty.
# Get your key from: https://openweathermap.org/api
# VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# ============================================================================
# SERVER-SIDE CONFIGURATION (process.env -- never sent to browser)
# ============================================================================

# --- MySQL / Cloud SQL -------------------------------------------------------
# [REQUIRED] Database connection for loads, fleet, accounting, settlements.
# For Cloud Run + Cloud SQL Proxy, set DB_SOCKET_PATH instead of DB_HOST.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=loadpilot_user
DB_PASSWORD=your_db_password_here
DB_NAME=loadpilot_production

# [OPTIONAL] Cloud SQL Auth Proxy Unix socket path (Cloud Run deployments).
# When set, DB_HOST and DB_PORT are ignored.
# DB_SOCKET_PATH=/cloudsql/YOUR_PROJECT:us-central1:loadpilot-db

# --- Firebase Admin SDK (Server) ---------------------------------------------
# [REQUIRED -- at least one] The server needs Firebase Admin credentials to
# verify ID tokens. Provide EITHER a service account JSON file OR the
# project ID (for Application Default Credentials on Cloud Run).
#
# Option A: Service account file (recommended for local dev)
#   Place serviceAccount.json in server/ -- auto-detected, no env var needed.
#   Or set the path explicitly:
# GOOGLE_APPLICATION_CREDENTIALS=./server/serviceAccount.json
#
# Option B: Project ID only (for Cloud Run with Workload Identity)
# FIREBASE_PROJECT_ID=your_project_id

# --- Google Gemini AI (Server) -----------------------------------------------
# [OPTIONAL] Powers AI-based BOL and Rate Confirmation document parsing.
# Without this key, /api/ai/* endpoints return 503.
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Maps (Server) ----------------------------------------------------
# [OPTIONAL] Server-side geocoding for load origin/destination resolution.
# Uses the same Google Maps Platform project as the frontend key, but should
# be a separate restricted key (HTTP referrer vs IP restriction).
# GOOGLE_MAPS_API_KEY=your_server_side_maps_key_here

# --- Weather (Server) --------------------------------------------------------
# [OPTIONAL] Server-side weather lookups for route planning.
# WEATHER_API_KEY=your_azure_maps_key_here

# --- CORS ---------------------------------------------------------------------
# [REQUIRED in production/staging] Frontend domain(s) allowed to call the API.
# Comma-separated for multiple origins. In development, defaults to localhost.
# CORS_ORIGIN=https://yourdomain.com
# CORS_ORIGIN=https://app.loadpilot.com,https://staging.loadpilot.com

# --- Express Server -----------------------------------------------------------
# [OPTIONAL] Server port. Defaults to 5000.
# PORT=5000

# [OPTIONAL] Node environment. Affects CORS validation and logging.
# Values: development | staging | production | test
NODE_ENV=development

# [OPTIONAL] Max API requests per IP per 15-minute window. Defaults to 100.
# RATE_LIMIT_MAX=100

# --- Identity & Auto-Provisioning --------------------------------------------
# [OPTIONAL] Controls whether unknown Firebase users are auto-provisioned
# with a new SQL profile on first login. Default: false (production-safe).
# When false, Firebase users without an existing SQL profile get 403.
# Set to "true" only during initial onboarding or controlled pilot.
# ALLOW_AUTO_PROVISION=false

# --- Secret Encryption --------------------------------------------------------
# [REQUIRED for tracking credential encryption] 32-byte hex key (64 hex chars)
# for encrypting tracking provider API tokens and webhook secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Falls back to QUICKBOOKS_TOKEN_ENCRYPTION_KEY if not set.
# SECRET_ENCRYPTION_KEY=your_64_char_hex_encryption_key_here
n# --- Object Storage Backend ----------------------------------------------------
# [OPTIONAL] Storage backend for uploaded documents. Default: disk.
# Set to "firebase" for Firebase Cloud Storage in production.
# STORAGE_BACKEND=disk

# [REQUIRED if STORAGE_BACKEND=firebase] Firebase Storage bucket name.
# FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# --- Authentication -----------------------------------------------------------
# [OPTIONAL] JWT signing secret. Not required when using Firebase Auth only.
# Only needed if you add custom JWT token issuance alongside Firebase.
# JWT_SECRET=your_jwt_secret_here

# --- Logging ------------------------------------------------------------------
# [OPTIONAL] Pino log level. Defaults to info.
# Values: fatal | error | warn | info | debug | trace | silent
# LOG_LEVEL=info

# [OPTIONAL] Application version tag included in structured log output.
# APP_VERSION=0.0.0

# --- Email / SMTP (Server) ----------------------------------------------------
# [OPTIONAL] SMTP credentials for email notifications (cert expiry alerts,
# load status updates, etc.). Without these, notifications log to console only.
# For development, use Ethereal Email: https://ethereal.email/create
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user@ethereal.email
SMTP_PASS=your_ethereal_password
SMTP_FROM=noreply@loadpilot.com

# --- FMCSA SAFER Web Services (Server) ---------------------------------------
# [OPTIONAL] FMCSA API key for real safety score lookups by USDOT number.
# Without this key, the safety endpoint returns mock/fallback data.
# Register at: https://mobile.fmcsa.dot.gov/developer/home
FMCSA_API_KEY=your_fmcsa_web_key_here

# [OPTIONAL] Override the FMCSA API base URL (for testing/staging).
# Default: https://mobile.fmcsa.dot.gov/qc/services/carriers
# FMCSA_API_BASE_URL=https://mobile.fmcsa.dot.gov/qc/services/carriers

# --- Stripe Billing (Server) --------------------------------------------------
# [REQUIRED for billing] Stripe API credentials for subscription management,
# checkout sessions, and webhook processing.
# Get your keys from: https://dashboard.stripe.com/apikeys
# Use test-mode keys (sk_test_*) for development; live keys (sk_live_*) for production.
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# [REQUIRED for billing] Stripe webhook signing secret for verifying webhook events.
# Get from: Stripe Dashboard > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# [REQUIRED for billing] Stripe Price IDs for each subscription tier.
# Create products and prices in Stripe Dashboard > Products, then copy the price_* IDs.
STRIPE_PRICE_RECORDS_VAULT=your_stripe_price_id_records_vault_here
STRIPE_PRICE_AUTOMATION_PRO=your_stripe_price_id_automation_pro_here
STRIPE_PRICE_FLEET_CORE=your_stripe_price_id_fleet_core_here
STRIPE_PRICE_FLEET_COMMAND=your_stripe_price_id_fleet_command_here

# --- Twilio SMS Notifications (Server) ---------------------------------------
# [OPTIONAL] Twilio credentials for sending SMS notifications (load status
# updates, driver alerts). Without these, SMS delivery is disabled and
# notifications fall back to email/in-app only.
# Get credentials from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# [OPTIONAL] Twilio phone number to send SMS from (E.164 format).
# Purchase a number at: https://console.twilio.com/us1/develop/phone-numbers
TWILIO_FROM_NUMBER=+15551234567

# --- QuickBooks Online Integration (Server) -----------------------------------
# [OPTIONAL] QuickBooks OAuth2 credentials for accounting sync (invoices,
# journal entries, chart of accounts). Without these, QuickBooks endpoints
# return 501 Not Implemented.
# Register your app at: https://developer.intuit.com/app/developer/qbo/docs
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id_here
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret_here

# [OPTIONAL] OAuth2 redirect URI registered with your QuickBooks app.
# Must match exactly what's configured in the Intuit Developer Portal.
# QUICKBOOKS_REDIRECT_URI=http://localhost:5000/callback/quickbooks

# [OPTIONAL] QuickBooks environment: sandbox (default) or production.
# Use sandbox for development and testing.
# QUICKBOOKS_ENVIRONMENT=sandbox

# [OPTIONAL] 32-byte hex key (64 hex chars) for encrypting stored OAuth tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this, token storage falls back to plaintext (not recommended for production).
QUICKBOOKS_TOKEN_ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# --- GPS / Vehicle Tracking (Server) -----------------------------------------
# [OPTIONAL] GPS telematics provider name. Defaults to "samsara".
# Supported values: samsara
# GPS_PROVIDER=samsara

# [OPTIONAL] Samsara API token for vehicle location and telematics data.
# Get from: Samsara Dashboard > Settings > API Tokens
# Required if GPS_PROVIDER=samsara.
SAMSARA_API_TOKEN=your_samsara_api_token_here

# [OPTIONAL] Shared secret for authenticating inbound GPS webhook payloads.
# Used by the /api/tracking/webhook endpoint to verify requests from the GPS provider.
GPS_WEBHOOK_SECRET=your_gps_webhook_secret_here

# --- Testing (not needed in production) ---------------------------------------
# [OPTIONAL] Firebase Web API key for integration tests that call Firebase
# REST Auth API directly. Not used by the application at runtime.
# FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# [OPTIONAL] Set to keep test logs visible (otherwise suppressed).
# DEBUG_TESTS=1

# [OPTIONAL] Set to require real infrastructure in integration tests.
# REQUIRE_INFRA=1
