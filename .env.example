# ============================================================================
# LoadPilot Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
#
# Variables are grouped by feature. Required vars are marked [REQUIRED];
# optional vars show their default value after the equals sign.
# ============================================================================

# --- Firebase Frontend Configuration (Vite) ----------------------------------
# These VITE_FIREBASE_* vars configure the Firebase JS SDK in the browser.
# Get them from: Firebase Console > Project Settings > General > Your apps
# [REQUIRED] All six are needed for authentication and Firestore to work.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# [OPTIONAL] Firebase Analytics measurement ID. Omit to disable analytics.
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Frontend API URL --------------------------------------------------------
# [OPTIONAL] Base URL for the Express API backend.
# Defaults to http://localhost:5000/api in development.
# Set to /api or https://api.yourdomain.com/api for production builds.
# VITE_API_URL=https://api.yourdomain.com/api

# --- Google Maps (Frontend) --------------------------------------------------
# [REQUIRED for fleet map] Powers GlobalMapView, geocoding, directions, and
# distance matrix in the browser. Without this key, map pages show a
# configuration prompt instead of rendering.
# Get your key from: https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API, Geocoding API, Directions API, Distance Matrix API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- Weather (Frontend) ------------------------------------------------------
# [OPTIONAL] Azure Maps subscription key for route weather overlays.
# Get your key from: https://azure.microsoft.com/en-us/products/azure-maps
# VITE_WEATHER_API_KEY=your_azure_maps_subscription_key_here

# [OPTIONAL] OpenWeatherMap fallback -- used when VITE_WEATHER_API_KEY is empty.
# Get your key from: https://openweathermap.org/api
# VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# ============================================================================
# SERVER-SIDE CONFIGURATION (process.env -- never sent to browser)
# ============================================================================

# --- MySQL / Cloud SQL -------------------------------------------------------
# [REQUIRED] Database connection for loads, fleet, accounting, settlements.
# For Cloud Run + Cloud SQL Proxy, set DB_SOCKET_PATH instead of DB_HOST.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=loadpilot_user
DB_PASSWORD=your_db_password_here
DB_NAME=loadpilot_production

# [OPTIONAL] Cloud SQL Auth Proxy Unix socket path (Cloud Run deployments).
# When set, DB_HOST and DB_PORT are ignored.
# DB_SOCKET_PATH=/cloudsql/YOUR_PROJECT:us-central1:loadpilot-db

# --- Firebase Admin SDK (Server) ---------------------------------------------
# [REQUIRED -- at least one] The server needs Firebase Admin credentials to
# verify ID tokens. Provide EITHER a service account JSON file OR the
# project ID (for Application Default Credentials on Cloud Run).
#
# Option A: Service account file (recommended for local dev)
#   Place serviceAccount.json in server/ -- auto-detected, no env var needed.
#   Or set the path explicitly:
# GOOGLE_APPLICATION_CREDENTIALS=./server/serviceAccount.json
#
# Option B: Project ID only (for Cloud Run with Workload Identity)
# FIREBASE_PROJECT_ID=your_project_id

# --- Google Gemini AI (Server) -----------------------------------------------
# [OPTIONAL] Powers AI-based BOL and Rate Confirmation document parsing.
# Without this key, /api/ai/* endpoints return 503.
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Maps (Server) ----------------------------------------------------
# [OPTIONAL] Server-side geocoding for load origin/destination resolution.
# Uses the same Google Maps Platform project as the frontend key, but should
# be a separate restricted key (HTTP referrer vs IP restriction).
# GOOGLE_MAPS_API_KEY=your_server_side_maps_key_here

# --- Weather (Server) --------------------------------------------------------
# [OPTIONAL] Server-side weather lookups for route planning.
# Set WEATHER_ENABLED=true to activate the weather service.
# WEATHER_ENABLED=false
# WEATHER_API_KEY=your_azure_maps_key_here

# --- CORS ---------------------------------------------------------------------
# [REQUIRED in production/staging] Frontend domain(s) allowed to call the API.
# Comma-separated for multiple origins. In development, defaults to localhost.
# CORS_ORIGIN=https://yourdomain.com
# CORS_ORIGIN=https://app.loadpilot.com,https://staging.loadpilot.com

# --- Express Server -----------------------------------------------------------
# [OPTIONAL] Server port. Defaults to 5000.
# PORT=5000

# [OPTIONAL] Node environment. Affects CORS validation and logging.
# Values: development | staging | production | test
NODE_ENV=development

# [OPTIONAL] Max API requests per IP per 15-minute window. Defaults to 100.
# RATE_LIMIT_MAX=100

# --- Authentication -----------------------------------------------------------
# [OPTIONAL] JWT signing secret. Not required when using Firebase Auth only.
# Only needed if you add custom JWT token issuance alongside Firebase.
# JWT_SECRET=your_jwt_secret_here

# --- Logging ------------------------------------------------------------------
# [OPTIONAL] Pino log level. Defaults to info.
# Values: fatal | error | warn | info | debug | trace | silent
# LOG_LEVEL=info

# [OPTIONAL] Application version tag included in structured log output.
# APP_VERSION=0.0.0

# --- Email / SMTP (Server) ----------------------------------------------------
# [OPTIONAL] SMTP credentials for email notifications (cert expiry alerts,
# load status updates, etc.). Without these, notifications log to console only.
# For development, use Ethereal Email: https://ethereal.email/create
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user@ethereal.email
SMTP_PASS=your_ethereal_password
SMTP_FROM=noreply@loadpilot.com

# --- FMCSA SAFER Web Services (Server) ---------------------------------------
# [OPTIONAL] FMCSA API key for real safety score lookups by USDOT number.
# Without this key, the safety endpoint returns mock/fallback data.
# Register at: https://mobile.fmcsa.dot.gov/developer/home
FMCSA_API_KEY=your_fmcsa_web_key_here

# [OPTIONAL] Override the FMCSA API base URL (for testing/staging).
# Default: https://mobile.fmcsa.dot.gov/qc/services/carriers
# FMCSA_API_BASE_URL=https://mobile.fmcsa.dot.gov/qc/services/carriers

# --- Testing (not needed in production) ---------------------------------------
# [OPTIONAL] Firebase Web API key for integration tests that call Firebase
# REST Auth API directly. Not used by the application at runtime.
# FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# [OPTIONAL] Set to keep test logs visible (otherwise suppressed).
# DEBUG_TESTS=1

# [OPTIONAL] Set to require real infrastructure in integration tests.
# REQUIRE_INFRA=1
